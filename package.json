{
  "name": "kylas-playwright-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright automation framework for Kylas Sales CRM",
  "author": "akashrn1801",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
"scripts": {
    "pretest": "if [ -z \"$CI\" ]; then bash scripts/rotate-reports.sh; fi",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --project=chromium",
    "test:leads": "playwright test tests/ui/leads/ --project=chromium",
    "test:rbac": "playwright test tests/rbac/ --project=chromium",
    "test:login": "playwright test tests/ui/dashboard/ --project=chromium",
    "test:deals": "playwright test tests/ui/deals/ tests/rbac/deals.rbac.spec.ts --project=chromium",
    "report:playwright": "playwright show-report reports/playwright-report",
    "report:allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:allure:open": "allure open reports/allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "clean": "rm -rf test-results reports/ allure-results"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "kylas",
    "crm",
    "enterprise"
  ],
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
