# =========================================
# ENVIRONMENT SELECTOR
# Values: qa | staging | prod
# =========================================
ENV=qa

# =========================================
# QA ENVIRONMENT
# =========================================
QA_APP_URL=https://app-qa.sling-dev.com
QA_API_BASE_URL=https://api-qa.sling-dev.com/v1

# =========================================
# STAGING ENVIRONMENT
# =========================================
STAGING_APP_URL=https://app-stage.sling-dev.com
STAGING_API_BASE_URL=https://api-stage.sling-dev.com/v1

# =========================================
# PRODUCTION ENVIRONMENT
# =========================================
PROD_APP_URL=https://app.kylas.io
PROD_API_BASE_URL=https://api.kylas.io/v1

# =========================================
# ADMIN USER (Full Access)
# =========================================
ADMIN_EMAIL=akash.nakhate@kylas.io
ADMIN_PASSWORD=Abc@12345

# =========================================
# RESTRICTED USER (Limited Access)
# =========================================
RESTRICTED_EMAIL=coowner@yopmail.com
RESTRICTED_PASSWORD=Abc@12345

# =========================================
# TIMEOUTS (milliseconds)
# =========================================
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
EXPECT_TIMEOUT=10000

# =========================================
# BROWSER SETTINGS
# =========================================
BROWSER=chromium
HEADLESS=true

# =========================================
# EXECUTION SETTINGS
# =========================================
WORKERS=4
RETRY_COUNT=1