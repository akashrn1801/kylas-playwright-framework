{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@modules/*": ["src/modules/*"],
      "@utils/*": ["src/utils/*"],
      "@data/*": ["src/data/*"],
      "@api/*": ["src/api/*"],
      "@auth/*": ["src/auth/*"],
      "@rbac/*": ["src/rbac/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "config/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
